{
  "name": "teraheadbms",
  "version": "2.0.0",
  "description": "TERAHEADBMS — Local Network BMS Desktop App",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "build": {
    "appId": "com.terahead.bms",
    "productName": "TERAHEADBMS",
    "copyright": "Copyright © 2026 TERAHEAD",
    "icon": "public/icon-512.png",
    "asar": true,
    "files": [
      "electron-main.js",
      "server.js",
      "package.json",
      "public/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "public/icon-512.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TERAHEADBMS"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon-512.png",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon-512.png",
      "category": "Office"
    },
    "directories": {
      "output": "dist"
    }
  },
  "license": "UNLICENSED"
}
